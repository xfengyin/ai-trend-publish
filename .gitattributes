# Git 属性配置
# 统一换行符和 diff 行为

# 自动处理换行符
* text=auto eol=lf

# 源代码文件
*.md text linguist-documentation
*.sh text eol=lf
*.ps1 text eol=crlf
*.yml text
*.yaml text
*.json text
*.toml text

# 文档文件
*.md diff=markdown

# 脚本文件
*.sh diff=bash
*.ps1 diff=text

# 配置文件
*.yml diff=text
*.yaml diff=text
*.json diff=text

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
