# EditorConfig 配置文件
# 统一编辑器风格
# 更多选项: https://editorconfig.org

root = true

[*]
# 字符编码
charset = utf-8

# 缩进风格
indent_style = space
indent_size = 2

# 换行符
end_of_line = lf

# 文件末尾插入空行
insert_final_newline = true

# 去除行尾空白
trim_trailing_whitespace = true

# 最大行长度
max_line_length = 100

[*.md]
# Markdown 文件保留行尾空白（用于换行）
trim_trailing_whitespace = false
max_line_length = 120

[*.{sh,bash}]
# Shell 脚本使用 2 空格缩进
indent_size = 2

[*.{yml,yaml}]
# YAML 文件使用 2 空格缩进
indent_size = 2

[*.json]
# JSON 文件使用 2 空格缩进
indent_size = 2

[Makefile]
# Makefile 使用 Tab
indent_style = tab
