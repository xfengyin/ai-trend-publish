# AI 智能体模板库 - 环境变量模板
# 复制此文件为 .env 并填入你的配置

# ============================================
# Claude Code 配置
# ============================================

# Claude Code 智能体目录（可选，默认: ~/.claude/agents）
# CLAUDE_AGENTS_PATH=/custom/path/to/agents

# Claude Code API 配置（如使用自定义 API）
# CLAUDE_API_KEY=your-api-key-here
# CLAUDE_API_URL=https://api.anthropic.com

# ============================================
# Cursor 配置
# ============================================

# Cursor 安装路径（Windows 可能需要配置）
# CURSOR_PATH=C:\Users\Username\AppData\Local\Programs\cursor

# Cursor API 配置
# CURSOR_API_KEY=your-api-key-here

# ============================================
# Aider 配置
# ============================================

# OpenAI API 配置
# OPENAI_API_KEY=your-openai-api-key

# Anthropic API 配置（Claude）
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Aider 模型选择
# AIDER_MODEL=gpt-4-turbo-preview

# ============================================
# DeepSeek 配置
# ============================================

# DeepSeek API 配置
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_API_URL=https://api.deepseek.com

# ============================================
# 豆包/字节跳动 配置
# ============================================

# 豆包 API 配置
# DOUBAO_API_KEY=your-doubao-api-key
# DOUBAO_API_URL=https://ark.cn-beijing.volces.com

# ============================================
# 飞书配置（用于飞书集成智能体）
# ============================================

# 飞书应用凭证
# FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书 Webhook（用于机器人推送）
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# ============================================
# 开发环境配置
# ============================================

# 调试模式
# DEBUG=true

# 日志级别 (debug, info, warn, error)
# LOG_LEVEL=info

# 安装脚本日志目录
# INSTALL_LOG_DIR=~/.ai-trend-publish/logs
